# Optilium Nest API base URL (no trailing slash)
#
# Development (with Vite proxy in vite.config.ts): use `/api` so requests stay same-origin
# (browser → http://localhost:8080/api/... → proxied to http://localhost:3000/...).
#
# Production (e.g. Vercel): use full backend URL — backend must allow your frontend origin in CORS.
# Example: https://api.example.com
VITE_API_BASE_URL=/api
